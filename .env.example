# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DOMAIN=localhost

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=secaudit
POSTGRES_USER=secaudit
POSTGRES_PASSWORD=changeme_use_a_strong_password

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_use_a_strong_password

# ─── Security (GENERATE NEW VALUES FOR PRODUCTION) ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme

# ─── Optional Local AI (Ollama) ──────────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── False Positive Reduction ────────────────────────────────────────────────
ENABLE_FINDING_CORRELATION=True
ENABLE_FINDING_SUPPRESSION=False
ENABLE_FINDING_VALIDATION=False
CORRELATION_MIN_SOURCES=2
CONFIDENCE_CONFIRMED_THRESHOLD=0.7
CONFIDENCE_SUSPICIOUS_THRESHOLD=0.4

# ─── Optional Email (for notifications) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@secaudit.local
